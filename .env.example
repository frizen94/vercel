# Configurações necessárias para o deploy na Vercel
# Configure estas variáveis na dashboard da Vercel em Project Settings > Environment Variables

# Database URL - Use seu banco PostgreSQL (recomendado: Neon, PlanetScale, ou Supabase)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Session Secret - Gere uma string aleatória para segurança
SESSION_SECRET=your-random-secret-key-here

# Node Environment (geralmente é definido automaticamente pela Vercel)
NODE_ENV=production